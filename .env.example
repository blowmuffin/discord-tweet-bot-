# Twitter API Bearer Token (from developer.twitter.com)
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Discord Webhook URL (shared, or per-account — see config/accounts.js)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Comma-separated Twitter usernames to track (overrides config/accounts.js defaults)
TWITTER_ACCOUNTS=AnthropicAI,OpenAI,sama

# Optional: per-account Discord webhook URLs
# DISCORD_WEBHOOK_ANTHROPIC=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_OPENAI=https://discord.com/api/webhooks/...

# Optional: error logging webhook (separate #bot-logs channel)
# DISCORD_ERROR_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: daily digest webhook (separate #tweet-digest channel)
# DISCORD_DIGEST_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: toggle retweets and replies (default: false)
INCLUDE_RETWEETS=false
INCLUDE_REPLIES=false
